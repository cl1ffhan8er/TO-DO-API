<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="to_do.TodoPage">

    <Grid>

        <!-- TASK LIST -->
        <CollectionView x:Name="taskList" Margin="10">
            
            <CollectionView.EmptyView>
                <StackLayout HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="10">
                    <Image Source="todolistemptypencil.png" WidthRequest="200" HeightRequest="200"> </Image>
                    <Label Text="No tasks yet." FontAttributes="Bold" FontSize="Large" HorizontalTextAlignment="Center"></Label>
                    <Label Text="Click + to add one." TextColor="Grey" FontSize="Small" HorizontalTextAlignment="Center"> </Label>

                </StackLayout>
            </CollectionView.EmptyView>
            
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame BorderColor="Gray"
                           Padding="10"
                           CornerRadius="10"
                           Margin="5">
                           

                        <VerticalStackLayout>

                            <Label Text="{Binding Title}"
                                   FontSize="18"
                                   FontAttributes="Bold"/>

                            <Label Text="{Binding Details}"
                                   FontSize="14"
                                   Margin="0,0,0,5"/>

                            <HorizontalStackLayout Spacing="10">

                                <Button Text="Edit"
                                        Clicked="OnEditClicked"/>

                                <Button Text="Delete"
                                        Clicked="OnDeleteClicked"
                                        BackgroundColor="Red"
                                        TextColor="White"/>

                                <Button Text="✓ Completed"
                                    Clicked="OnCompletedClicked"
                                    BackgroundColor="Green"
                                    TextColor="White"/>

                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>


        <!-- FLOATING ADD BUTTON -->
        <Button Text="+"
                FontSize="30"
                WidthRequest="70"
                HeightRequest="70"
                CornerRadius="35"
                BackgroundColor="DodgerBlue"
                TextColor="White"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                Clicked="OnAddClicked"/>

    </Grid>

</ContentPage>